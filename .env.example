# Instagram / Meta
META_VERIFY_TOKEN=your_verify_token_here
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_APP_SECRET=your_app_secret_here
INSTAGRAM_ACCOUNT_ID=your_ig_account_id_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# App
AUTO_MODE=false
FLASK_PORT=5000
DATABASE_PATH=conversations.db

# Claude
CLAUDE_MODE=cli
# cli = Claude Code OAuth (subprocess)
# api = Anthropic API key
ANTHROPIC_API_KEY=optional_if_using_cli
